# ─── Copie ce fichier en .env.local et remplis les valeurs ───────────────────
# .env.local est gitignored — ne jamais committer tes vraies clés

# Supabase — récupère ces valeurs dans :
# https://app.supabase.com → ton projet → Settings → API
VITE_SUPABASE_URL=https://TON_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# (optionnel — pour le backend Express plus tard)
# VITE_API_URL=http://localhost:3001
# VITE_SOCKET_URL=http://localhost:3001

# Backend API (décommenter quand geocards-api tourne)
VITE_API_URL=http://localhost:3001

# Cloudflare Turnstile (anti-bot quiz)
# Créer un site sur https://dash.cloudflare.com/turnstile → Widget type: Invisible
# VITE_TURNSTILE_SITE_KEY=0x...
